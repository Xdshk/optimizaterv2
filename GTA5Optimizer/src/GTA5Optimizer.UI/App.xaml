<Application x:Class="GTA5Optimizer.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GTA5Optimizer.UI.Converters"
>
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Themes.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
            <converters:BytesToMBConverter x:Key="BytesToMBConverter"/>
            <converters:SeverityToColorConverter x:Key="SeverityToColorConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
