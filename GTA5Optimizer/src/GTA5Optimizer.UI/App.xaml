<Application x:Class="GTA5Optimizer.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GTA5Optimizer.UI.Converters">
    <Application.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <converters:BytesToMBConverter x:Key="BytesToMBConverter"/>
        <converters:HasContentToVisibilityConverter x:Key="HasContentToVisibilityConverter"/>
        <converters:SeverityToColorConverter x:Key="SeverityToColorConverter"/>
    </Application.Resources>
</Application>
