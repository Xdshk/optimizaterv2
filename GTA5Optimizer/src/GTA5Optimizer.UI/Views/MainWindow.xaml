<Window x:Class="GTA5Optimizer.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="GTA5 Optimizer • Majestic RP"
        Height="780" Width="1150"
        WindowStartupLocation="CenterScreen"
        Background="#0D0D0D"
        WindowStyle="None"
        AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/Themes.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Card Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#161616"/>
            <Setter Property="BorderBrush" Value="#222222"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>

        <!-- Metric Card Style -->
        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#161616" Offset="0"/>
                        <GradientStop Color="#111111" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#252525"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <!-- Toggle Switch Style -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Border x:Name="Track" Width="40" Height="22" CornerRadius="11" Background="#2A2A2A"/>
                            <Border x:Name="Thumb" Width="18" Height="18" CornerRadius="9" Background="#555555" HorizontalAlignment="Left" Margin="2,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#00D4FF"/>
                                <Setter TargetName="Thumb" Property="Background" Value="White"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <converters:SeverityToColorConverter x:Key="SeverityToColorConverter" xmlns:converters="clr-namespace:GTA5Optimizer.UI.Converters"/>
    </Window.Resources>

    <Border CornerRadius="12" Background="#0D0D0D" BorderBrush="#1A1A1A" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>

            <!-- ===== ЗАГОЛОВОК ===== -->
            <Border Grid.Row="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#141414" Offset="0"/>
                        <GradientStop Color="#1A1A1A" Offset="0.5"/>
                        <GradientStop Color="#141414" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Path Data="M 6 2 L 10 8 L 6 14 L 2 8 Z" Fill="#00D4FF" Width="14" Height="16" Stretch="Uniform" VerticalAlignment="Center">
                            <Path.Effect>
                                <DropShadowEffect Color="#00D4FF" Opacity="0.6" ShadowDepth="0" BlurRadius="8"/>
                            </Path.Effect>
                        </Path>
                        <TextBlock Text="GTA5" Foreground="White" FontSize="16" FontWeight="Light" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        <TextBlock Text="OPTIMIZER" Foreground="White" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Border Background="#1E1E1E" CornerRadius="4" Padding="6,2" Margin="10,0,0,0">
                            <TextBlock Text="Majestic RP" Foreground="#00D4ff" FontSize="10" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                            <Ellipse Width="6" Height="6" Margin="0,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#00E676"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOptimizing}" Value="True">
                                                <Setter Property="Fill" Value="#FFAB00"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.4" To="1" Duration="0:0:1.2">
                                                    <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <TextBlock Text="{Binding StatusMessage}" Foreground="#555555" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Button Content="─" Width="30" Height="30" Background="Transparent" Foreground="#444444"
                                BorderThickness="0" FontSize="10" Cursor="Hand" Margin="0,0,4,0" Click="MinimizeButton_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="Transparent" CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#2A2A2A"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="✕" Width="30" Height="30" Background="Transparent" Foreground="#444444"
                                BorderThickness="0" FontSize="12" Cursor="Hand" Click="CloseButton_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="Transparent" CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#FF5252"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== КОНТЕНТ ===== -->
            <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Padding="0">
                <TabControl.Resources>
                    <Style TargetType="TabControl" BasedOn="{StaticResource ModernTabControl}"/>
                    <Style TargetType="TabItem" BasedOn="{StaticResource ModernTabItem}"/>
                </TabControl.Resources>

                <!-- ОПТИМИЗАЦИЯ -->
                <TabItem Header="Оптимизация">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16">
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                                <Grid Margin="18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="ПРОФИЛЬ ОПТИМИЗАЦИИ" Foreground="#444444" FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <ComboBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfileConfig}"
                                                  DisplayMemberPath="Name" Width="230" HorizontalAlignment="Left" Height="38" FontSize="13"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding SelectedProfileConfig.Description, TargetNullValue='Выберите профиль', FallbackValue='Выберите профиль'}"
                                               Foreground="#555555" VerticalAlignment="Center" FontSize="12" Margin="20,0,0,0"/>
                                </Grid>
                            </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Button Content="⚡  ОПТИМИЗИРОВАТЬ" Command="{Binding OptimizeCommand}"
                                        IsEnabled="{Binding IsOptimizing, Converter={StaticResource InverseBooleanConverter}}"
                                        Height="48" Width="220" Style="{StaticResource PrimaryButtonStyle}"/>
                                <Button Content="↩ Восстановить" Command="{Binding RestoreDefaultsCommand}"
                                        IsEnabled="{Binding IsOptimizing, Converter={StaticResource InverseBooleanConverter}}"
                                        Height="48" Width="155" Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0"/>
                                <Button Content="🔄 Метрики" Command="{Binding RefreshMetricsCommand}"
                                        Height="48" Width="120" Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0"/>
                            </StackPanel>

                            <UniformGrid Columns="4" Margin="0,0,0,16">
                                <Border Style="{StaticResource MetricCard}" Margin="0,0,6,0">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="SpaceBetween">
                                            <TextBlock Text="FPS" Foreground="#555555" FontSize="10" FontWeight="Bold"/>
                                            <Ellipse Width="6" Height="6" Fill="#00E676"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding CurrentFPS, StringFormat={}{0:F0}, TargetNullValue=—}" Foreground="White" FontSize="36" FontWeight="Light" Margin="0,8,0,0"/>
                                        <ProgressBar Value="{Binding CurrentFPS}" Maximum="144" Height="3" Margin="0,10,0,0" Foreground="#00E676" Background="#1A1A1A"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCard}" Margin="6,0,6,0">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="SpaceBetween">
                                            <TextBlock Text="CPU" Foreground="#555555" FontSize="10" FontWeight="Bold"/>
                                            <Ellipse Width="6" Height="6" Fill="#00D4FF"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Baseline" Margin="0,8,0,0">
                                            <TextBlock Text="{Binding CpuUsage, StringFormat={}{0:F0}}" Foreground="White" FontSize="36" FontWeight="Light"/>
                                            <TextBlock Text="%" Foreground="#555555" FontSize="16" FontWeight="Light"/>
                                        </StackPanel>
                                        <ProgressBar Value="{Binding CpuUsage}" Maximum="100" Height="3" Margin="0,10,0,0" Foreground="#00D4FF" Background="#1A1A1A"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCard}" Margin="6,0,6,0">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="SpaceBetween">
                                            <TextBlock Text="GPU" Foreground="#555555" FontSize="10" FontWeight="Bold"/>
                                            <Ellipse Width="6" Height="6" Fill="#FF6D00"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Baseline" Margin="0,8,0,0">
                                            <TextBlock Text="{Binding GpuUsage, StringFormat={}{0:F0}}" Foreground="White" FontSize="36" FontWeight="Light"/>
                                            <TextBlock Text="%" Foreground="#555555" FontSize="16" FontWeight="Light"/>
                                        </StackPanel>
                                        <ProgressBar Value="{Binding GpuUsage}" Maximum="100" Height="3" Margin="0,10,0,0" Foreground="#FF6D00" Background="#1A1A1A"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource MetricCard}" Margin="6,0,0,0">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="SpaceBetween">
                                            <TextBlock Text="RAM" Foreground="#555555" FontSize="10" FontWeight="Bold"/>
                                            <Ellipse Width="6" Height="6" Fill="#FFAB00"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Baseline" Margin="0,8,0,0">
                                            <TextBlock Text="{Binding RamUsage, StringFormat={}{0:F0}}" Foreground="White" FontSize="36" FontWeight="Light"/>
                                            <TextBlock Text="%" Foreground="#555555" FontSize="16" FontWeight="Light"/>
                                        </StackPanel>
                                        <ProgressBar Value="{Binding RamUsage}" Maximum="100" Height="3" Margin="0,10,0,0" Foreground="#FFAB00" Background="#1A1A1A"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- МОНИТОРИНГ -->
                <TabItem Header="Мониторинг">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,12">
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,6,0">
                                <StackPanel Margin="16">
                                    <TextBlock Text="🖥  CPU" Foreground="#00D4FF" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Загрузка" Foreground="#555555" FontSize="11"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Monitor.Metrics.CPUUsage, StringFormat={}{0:F1}%}" Foreground="White" FontSize="11"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Игра" Foreground="#555555" FontSize="11"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Monitor.Metrics.CPUUsageGame, StringFormat={}{0:F1}%}" Foreground="White" FontSize="11"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Температура" Foreground="#555555" FontSize="11"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Monitor.Metrics.CPUTemperature, StringFormat={}{0:F0}°C}" Foreground="White" FontSize="11"/>
                                    </Grid>
                                    <ProgressBar Value="{Binding Monitor.Metrics.CPUUsage}" Maximum="100" Height="3" Margin="0,10,0,0" Foreground="#00D4FF" Background="#1A1A1A"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Margin="6,0,6,0">
                                <StackPanel Margin="16">
                                    <TextBlock Text="💾  RAM" Foreground="#FFAB00" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Использовано" Foreground="#555555" FontSize="11"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Foreground="White" FontSize="11">
                                            <TextBlock.Text><Binding Path="Monitor.Metrics.UsedRAM" Converter="{StaticResource BytesToMBConverter}"/></TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Standby" Foreground="#555555" FontSize="11"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Monitor.Metrics.StandbyMemoryMB, StringFormat={}{0:F0} MB}" Foreground="White" FontSize="11"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Игра" Foreground="#555555" FontSize="11"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Monitor.Metrics.GameRAM_MB, StringFormat={}{0:F0} MB}" Foreground="White" FontSize="11"/>
                                    </Grid>
                                    <ProgressBar Value="{Binding Monitor.Metrics.RAMUsagePercent}" Maximum="100" Height="3" Margin="0,10,0,0" Foreground="#FFAB00" Background="#1A1A1A"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Margin="6,0,0,0">
                                <StackPanel Margin="16">
                                    <TextBlock Text="📡  Диск &amp; Сеть" Foreground="#FF6D00" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Чтение" Foreground="#555555" FontSize="11"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Monitor.Metrics.DiskReadSpeedMBps, StringFormat={}{0:F1} MB/s}" Foreground="White" FontSize="11"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Запись" Foreground="#555555" FontSize="11"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Monitor.Metrics.DiskWriteSpeedMBps, StringFormat={}{0:F1} MB/s}" Foreground="White" FontSize="11"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Пинг" Foreground="#555555" FontSize="11"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Monitor.Metrics.CurrentPing, StringFormat={}{0:F0} ms}" Foreground="White" FontSize="11"/>
                                    </Grid>
                                    <ProgressBar Value="{Binding Monitor.Metrics.DiskActiveTimePercent}" Maximum="100" Height="3" Margin="0,10,0,0" Foreground="#FF6D00" Background="#1A1A1A"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                            <StackPanel Margin="16">
                                <TextBlock Text="🔍  АНАЛИЗ УЗКИХ МЕСТ" Foreground="White" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding Monitor.Bottleneck.PrimaryBottleneck, StringFormat={}Основное ограничение: {0}, TargetNullValue='Анализ...', FallbackValue='Анализ...'}" Foreground="#555555" FontSize="11" Margin="0,0,0,12"/>
                                <ItemsControl ItemsSource="{Binding Monitor.Bottleneck.Details}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#111111" CornerRadius="8" Padding="12" Margin="0,4">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Severity, StringFormat={}{0:F0}}" FontWeight="Bold" FontSize="14" Width="40"
                                                                   Foreground="{Binding Severity, Converter={StaticResource SeverityToColorConverter}}"/>
                                                        <TextBlock Text="{Binding Description}" Foreground="#CCCCCC" FontSize="12" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Recommendation}" Foreground="#555555" FontSize="11" Margin="40,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border Margin="0,12,0,0" CornerRadius="8" Padding="12">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#0A2E0A"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Monitor.Metrics.IsPerformanceGood}" Value="False">
                                                    <Setter Property="Background" Value="#2E0A0A"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Monitor.Metrics.PerformanceStatus}" FontSize="18" FontWeight="Light" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#00E676"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Monitor.Metrics.IsPerformanceGood}" Value="False">
                                                        <Setter Property="Foreground" Value="#FF5252"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ЛОГИ -->
                <TabItem Header="Логи">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                            <Button Content="↻ Обновить" Command="{Binding Logs.RefreshCommand}" Style="{StaticResource SecondaryButtonStyle}" Height="32" Width="110"/>
                            <Button Content="🗑 Очистить" Command="{Binding Logs.ClearCommand}" Style="{StaticResource SecondaryButtonStyle}" Height="32" Width="100" Margin="8,0,0,0"/>
                            <TextBlock Foreground="#444444" VerticalAlignment="Center" FontSize="11" Margin="15,0,0,0">
                                <Run Text="Записей: "/><Run Text="{Binding Logs.Logs.Count, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                            <ListView ItemsSource="{Binding Logs.Logs}" Background="Transparent" BorderThickness="0"
                                      Foreground="#CCCCCC" FontSize="12" FontFamily="Consolas, 'Courier New', monospace"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="12,5"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="BorderBrush" Value="#1A1A1A"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#181818"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="75"/>
                                                <ColumnDefinition Width="85"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding ShortTime}" Foreground="#444444" FontSize="11"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Level}" FontSize="11" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#666666"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Level}" Value="Information"><Setter Property="Foreground" Value="#00D4FF"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}" Value="Warning"><Setter Property="Foreground" Value="#FFAB00"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}" Value="Error"><Setter Property="Foreground" Value="#FF5252"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}" Value="Critical"><Setter Property="Foreground" Value="#FF1744"/></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Grid.Column="2" Text="{Binding Category}" Foreground="#333333" FontSize="11"/>
                                            <TextBlock Grid.Column="3" Text="{Binding Message}" Foreground="#AAAAAA" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- НАСТРОЙКИ -->
                <TabItem Header="Настройки">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16">
                        <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                                <StackPanel Margin="18">
                                    <TextBlock Text="⚙ ПРОФИЛЬ ПО УМОЛЧАНИЮ" Foreground="White" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <ComboBox ItemsSource="{Binding Settings.AvailableProfiles}" SelectedItem="{Binding Settings.SelectedProfileName}"
                                              Width="280" Height="36" HorizontalAlignment="Left" FontSize="13"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                                <StackPanel Margin="18">
                                    <TextBlock Text="🔄 АВТООПТИМИЗАЦИЯ" Foreground="White" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <CheckBox Content="Включить автооптимизацию" IsChecked="{Binding Settings.EnableAutoOptimization}" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Интервал:" Foreground="#555555" FontSize="12" VerticalAlignment="Center" Width="80"/>
                                        <TextBlock Text="{Binding Settings.AutoOptimizationInterval}" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBlock Text=" сек" Foreground="#555555" FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Оверлей и автозапуск -->
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                                <StackPanel Margin="18">
                                    <TextBlock Text="🎮 ИГРОВЫЕ ФУНКЦИИ" Foreground="White" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding OverlayEnabled}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Оверлей в игре (FPS, CPU, GPU)" Foreground="#AAAAAA" FontSize="12" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding AutoStartEnabled}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Автозапуск с Windows" Foreground="#AAAAAA" FontSize="12" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="Горячая клавиша: Ctrl+Alt+O — быстрая оптимизация" Foreground="#444444" FontSize="10" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                                <StackPanel Margin="18">
                                    <TextBlock Text="🎯 ДОПОЛНИТЕЛЬНО" Foreground="White" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <CheckBox Content="Закрывать браузеры" IsChecked="{Binding Settings.CloseBrowsers}" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,6"/>
                                    <CheckBox Content="Отключать Discord Overlay" IsChecked="{Binding Settings.CloseDiscordOverlay}" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,6"/>
                                    <CheckBox Content="Очищать память" IsChecked="{Binding Settings.EnableMemoryCleanup}" Foreground="#AAAAAA" FontSize="12"/>
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Button Content="💾 Сохранить" Command="{Binding Settings.SaveCommand}" Style="{StaticResource PrimaryButtonStyle}" Height="40" Width="150"/>
                                <Button Content="↩ Сбросить" Command="{Binding Settings.ResetCommand}" Style="{StaticResource SecondaryButtonStyle}" Height="40" Width="130" Margin="10,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>

            <!-- СТАТУС-БАР -->
            <Border Grid.Row="2" Background="#111111" BorderBrush="#1A1A1A" BorderThickness="0,1,0,0">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding GameStatusText}" Foreground="#444444" FontSize="10" VerticalAlignment="Center"/>
                        <TextBlock Text="  •  " Foreground="#2A2A2A" FontSize="10" VerticalAlignment="Center"/>
                        <TextBlock Foreground="#333333" FontSize="10" VerticalAlignment="Center">
                            <Run Text="Ctrl+Alt+O — оптимизация"/>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Foreground="#333333" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <Run Text="GTA5 Optimizer "/><Run Text="{Binding Version}"/>
                    </TextBlock>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
