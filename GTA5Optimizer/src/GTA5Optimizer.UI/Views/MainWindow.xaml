<Window x:Class="GTA5Optimizer.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="GTA5 Optimizer &amp; Majestic RP"
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Window.Background>
        <SolidColorBrush Color="#121212"/>
    </Window.Background>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#1e1e1e" BorderBrush="#333333" BorderThickness="0,0,0,1">
            <DockPanel Margin="20,0" LastChildFill="True">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="GTA5 Optimizer"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" &amp; Majestic RP"
                               Foreground="#00d4ff"
                               FontSize="20"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding StatusMessage}"
                           Foreground="#00ff88"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- Контент -->
        <TabControl Grid.Row="1" SelectedIndex="0">
            <TabItem Header="Оптимизация">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Профиль -->
                    <GroupBox Grid.Row="0" Header="Профиль оптимизации" Margin="10">
                        <StackPanel Orientation="Horizontal">
                            <ComboBox ItemsSource="{Binding Profiles}"
                                      SelectedItem="{Binding SelectedProfileConfig}"
                                      DisplayMemberPath="Name"
                                      Width="200"/>
                            <TextBlock Text="{Binding SelectedProfileConfig.Description}"
                                       VerticalAlignment="Center"
                                       Foreground="#aaaaaa"
                                       Margin="10,0,0,0"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- Кнопка оптимизации -->
                    <Border Grid.Row="1" Margin="10">
                        <Button Content="OPTIMIZE"
                                Command="{Binding OptimizeCommand}"
                                IsEnabled="{Binding IsOptimizing, Converter={StaticResource InverseBooleanConverter}}"
                                Width="200"
                                Height="40"
                                Background="#00d4ff"
                                Foreground="#000000"
                                FontWeight="Bold"
                                FontSize="14"/>
                    </Border>

                    <!-- Метрики -->
                    <Border Grid.Row="2" Margin="10">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                            <Border Width="150" Padding="10" Background="#1e1e1e" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="FPS" Foreground="#888888" FontSize="12"/>
                                    <TextBlock Text="{Binding CurrentFPS, StringFormat={}{0:F1}}" Foreground="#00ff88" FontSize="18" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Width="150" Padding="10" Background="#1e1e1e" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="CPU" Foreground="#888888" FontSize="12"/>
                                    <TextBlock Text="{Binding CPUUsage, StringFormat={}{0:F1}%}" Foreground="#00d4ff" FontSize="18" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Width="150" Padding="10" Background="#1e1e1e" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="GPU" Foreground="#888888" FontSize="12"/>
                                    <TextBlock Text="{Binding GPUUsage, StringFormat={}{0:F1}%}" Foreground="#ff6600" FontSize="18" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Width="150" Padding="10" Background="#1e1e1e" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="RAM" Foreground="#888888" FontSize="12"/>
                                    <TextBlock Text="{Binding RAMUsage, StringFormat={}{0:F1}%}" Foreground="#ff6600" FontSize="18" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <TabControl Grid.Row="3" Margin="10">
                        <TabItem Header="Мониторинг"/>
                        <TabItem Header="Логи"/>
                        <TabItem Header="Настройки"/>
                    </TabControl>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
