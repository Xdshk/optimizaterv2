<Window x:Class="GTA5Optimizer.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="GTA5 Optimizer • Majestic RP"
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#0A0A0F"
        WindowStyle="None"
        AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" xmlns:converters="clr-namespace:GTA5Optimizer.UI.Converters"/>
        <converters:HasContentToVisibilityConverter x:Key="HasContentToVisibilityConverter" xmlns:converters="clr-namespace:GTA5Optimizer.UI.Converters"/>
        <converters:SeverityToColorConverter x:Key="SeverityToColorConverter" xmlns:converters="clr-namespace:GTA5Optimizer.UI.Converters"/>
        <converters:BytesToMBConverter x:Key="BytesToMBConverter" xmlns:converters="clr-namespace:GTA5Optimizer.UI.Converters"/>

        <SolidColorBrush x:Key="Hud.Background" Color="#05050A"/>
        <SolidColorBrush x:Key="Hud.Panel" Color="#0B0B14"/>
        <SolidColorBrush x:Key="Hud.Panel.Strong" Color="#11111E"/>
        <SolidColorBrush x:Key="Hud.Panel.Soft" Color="#151526"/>
        <SolidColorBrush x:Key="Hud.Border" Color="#202035"/>
        <SolidColorBrush x:Key="Hud.Border.Soft" Color="#17172A"/>
        <SolidColorBrush x:Key="Hud.Text" Color="#F5F7FF"/>
        <SolidColorBrush x:Key="Hud.Text.Muted" Color="#8B90A8"/>
        <SolidColorBrush x:Key="Hud.Text.Subtle" Color="#5E637C"/>
        <SolidColorBrush x:Key="Hud.Accent" Color="#6366F1"/>
        <SolidColorBrush x:Key="Hud.Accent.Green" Color="#22C55E"/>
        <SolidColorBrush x:Key="Hud.Accent.Orange" Color="#F59E0B"/>
        <SolidColorBrush x:Key="Hud.Accent.Pink" Color="#EC4899"/>
        <SolidColorBrush x:Key="Hud.Danger" Color="#EF4444"/>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{StaticResource Hud.Text.Muted}"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#151526" Offset="0"/>
                        <GradientStop Color="#0D0D18" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#F5F7FF"/>
            <Setter Property="BorderBrush" Value="#26263D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="toggle" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0" Content="{TemplateBinding Content}" VerticalAlignment="Center"/>
                                                <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z" Fill="#A78BFA" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="popup" IsOpen="{Binding IsDropDownOpen, ElementName=toggle}" Placement="Bottom" AllowsTransparency="True">
                                <Border Background="#0D0D18" BorderBrush="#26263D" BorderThickness="1" CornerRadius="12" Padding="4" Margin="0,4,0,0">
                                    <ScrollViewer MaxHeight="260">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#11111E" Offset="0"/>
                        <GradientStop Color="#0B0B14" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#202035"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="0" Opacity="0.25"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Metric Card Style -->
        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#151526" Offset="0"/>
                        <GradientStop Color="#0E0E18" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#26263D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="0" Opacity="0.18"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C3AED" Offset="0"/>
                        <GradientStop Color="#6366F1" Offset="0.55"/>
                        <GradientStop Color="#06B6D4" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="22,13"/>
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderThickness="1" BorderBrush="#2A2A55" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#A78BFA" Offset="0"/>
                                            <GradientStop Color="#818CF8" Offset="0.55"/>
                                            <GradientStop Color="#22D3EE" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#6366F1" BlurRadius="18" ShadowDepth="0" Opacity="0.35"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="0.98" ScaleY="0.98"/></Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary Button -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#171726" Offset="0"/>
                        <GradientStop Color="#10101A" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#F5F7FF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#26263D"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="18,11"/>
            <Setter Property="MinHeight" Value="38"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#202036" Offset="0"/>
                                            <GradientStop Color="#161626" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="border" Property="BorderBrush" Value="#6366F1"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="0.985" ScaleY="0.985"/></Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Social Icon Button -->
        <Style x:Key="SocialIconButton" TargetType="Button">
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="#10101A" BorderBrush="#202035" BorderThickness="1" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#171726"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#6366F1"/>
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.04" ScaleY="1.04"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0D0D14"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle Switch -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Border x:Name="Track" Width="44" Height="24" CornerRadius="12" Background="#2A2A3E"/>
                            <Border x:Name="Thumb" Width="20" Height="20" CornerRadius="10" Background="#555570" HorizontalAlignment="Left" Margin="2,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#6366F1"/>
                                <Setter TargetName="Thumb" Property="Background" Value="White"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== SCROLLBAR STYLE ===== -->
        <Style x:Key="HudScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="MinWidth" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Bg" Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True" IsEnabled="{TemplateBinding IsMouseOver}">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="thumb" CornerRadius="3" Opacity="0.35">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#6366F1" Offset="0"/>
                                                            <GradientStop Color="#A78BFA" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="thumb" Property="Opacity" Value="0.7"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="thumb" Property="Opacity" Value="0.9"/>
                                                        <Setter TargetName="thumb" Property="Background">
                                                            <Setter.Value>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                    <GradientStop Color="#818CF8" Offset="0"/>
                                                                    <GradientStop Color="#C4B5FD" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HudScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar" Grid.Column="1"
                                       Style="{StaticResource HudScrollBar}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== BENCHMARK HUD BUTTONS ===== -->
        <Style x:Key="BenchmarkPrimaryButton" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#F59E0B" Offset="0"/>
                        <GradientStop Color="#EF4444" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderThickness="1" BorderBrush="#F59E0B" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect Color="#F59E0B" BlurRadius="12" ShadowDepth="0" Opacity="0.2"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FBBF24" Offset="0"/>
                                            <GradientStop Color="#F87171" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#F59E0B" BlurRadius="22" ShadowDepth="0" Opacity="0.45"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="0.97" ScaleY="0.97"/></Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BenchmarkSecondaryButton" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A1A2E" Offset="0"/>
                        <GradientStop Color="#11111E" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2A2A45"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#252540" Offset="0"/>
                                            <GradientStop Color="#1A1A30" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="border" Property="BorderBrush" Value="#F59E0B"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#F59E0B" BlurRadius="10" ShadowDepth="0" Opacity="0.2"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="0.97" ScaleY="0.97"/></Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== BENCHMARK DURATION CHIP ===== -->
        <Style x:Key="DurationChipStyle" TargetType="RadioButton">
            <Setter Property="GroupName" Value="DurationGroup"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="chip" CornerRadius="10" Padding="14,8" BorderThickness="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#151526" Offset="0"/>
                                    <GradientStop Color="#0E0E18" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#26263D"/>
                            </Border.BorderBrush>
                            <TextBlock x:Name="label" Text="{TemplateBinding Content}" Foreground="#8B90A8"
                                       FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="chip" Property="BorderBrush" Value="#6366F1"/>
                                <Setter TargetName="chip" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1E1E38" Offset="0"/>
                                            <GradientStop Color="#151526" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="label" Property="Foreground" Value="#C7CBE2"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="chip" Property="BorderBrush" Value="#F59E0B"/>
                                <Setter TargetName="chip" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#2A2010" Offset="0"/>
                                            <GradientStop Color="#1A1508" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="chip" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#F59E0B" BlurRadius="12" ShadowDepth="0" Opacity="0.3"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="label" Property="Foreground" Value="#FBBF24"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Navigation Button Style -->
        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#737895"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="14" Padding="{TemplateBinding Padding}"
                                BorderThickness="0">
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="iconBox" Width="32" Height="32" CornerRadius="10" Background="Transparent">
                                    <TextBlock x:Name="icon" Text="{TemplateBinding Tag}" FontSize="17"
                                               Foreground="{TemplateBinding Foreground}"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="label" Text="{TemplateBinding Content}"
                                           VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#151525"/>
                                <Setter Property="Foreground" Value="#C7CBE2"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#15152A" Offset="0"/>
                                            <GradientStop Color="#10101A" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="border" Property="BorderBrush" Value="#6366F1"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="1"/>
                                <Setter TargetName="iconBox" Property="Background" Value="#1A1A35"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border CornerRadius="22" Background="#05050A" BorderBrush="#1D1D32" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="62"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="32"/>
            </Grid.RowDefinitions>

            <!-- ===== HEADER ===== -->
            <Border Grid.Row="0" BorderBrush="#1D1D32" BorderThickness="0,0,0,1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0F0F1A" Offset="0"/>
                        <GradientStop Color="#07070D" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid Margin="22,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="GTA5" Foreground="#A78BFA" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <TextBlock Text="OPTIMIZER" Foreground="#FFFFFF" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Border CornerRadius="8" Padding="8,4" Margin="12,0,0,0" BorderBrush="#2A2A55" BorderThickness="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#151530" Offset="0"/>
                                    <GradientStop Color="#0E0E18" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="Majestic RP" Foreground="#22D3EE" FontSize="11" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                            <Ellipse Width="7" Height="7" Margin="0,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#22C55E"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOptimizing}" Value="True">
                                                <Setter Property="Fill" Value="#F59E0B"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.4" To="1" Duration="0:0:1.2">
                                                    <DoubleAnimation.EasingFunction><SineEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                            <TextBlock Text="{Binding StatusMessage}" Foreground="#A0A4BD" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="▶" ToolTip="YouTube" Tag="https://www.youtube.com/@juziksuzuykin" Style="{StaticResource SocialIconButton}" Click="SocialButton_Click"/>
                            <Button Content="♪" ToolTip="TikTok" Tag="https://www.tiktok.com/@juzikxd" Style="{StaticResource SocialIconButton}" Click="SocialButton_Click"/>
                            <Button Content="D" ToolTip="Discord" Tag="https://discord.gg/juzikxdshka" Style="{StaticResource SocialIconButton}" Click="SocialButton_Click"/>
                            <Button Content="D" ToolTip="Discord 2" Tag="https://discord.gg/TX77XhEW" Style="{StaticResource SocialIconButton}" Click="SocialButton_Click"/>
                        </StackPanel>

                        <Button Content="─" Width="32" Height="32" Background="Transparent" Foreground="#444460"
                                BorderThickness="0" FontSize="10" Cursor="Hand" Margin="4,0,0,0" Click="MinimizeButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="Transparent" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#1E1E30"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Content="✕" Width="32" Height="32" Background="Transparent" Foreground="#444460"
                                BorderThickness="0" FontSize="12" Cursor="Hand" Margin="4,0,0,0" Click="CloseButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="Transparent" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#EF4444"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== CONTENT ===== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ===== SIDEBAR NAVIGATION ===== -->
                <Border Grid.Column="0" BorderBrush="#1D1D32" BorderThickness="0,0,1,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#0B0B14" Offset="0"/>
                            <GradientStop Color="#07070D" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel Margin="10,14">
                        <TextBlock Text="НАВИГАЦИЯ" Foreground="#3F4666" FontSize="10" FontWeight="Bold" Margin="12,0,0,10"/>

                        <RadioButton x:Name="NavOptimization" Content="Оптимизация" Tag="⚡"
                                     Style="{StaticResource NavButtonStyle}"
                                     Checked="NavButton_Checked"/>
                        <RadioButton x:Name="NavMonitoring" Content="Мониторинг" Tag="📊"
                                     Style="{StaticResource NavButtonStyle}"
                                     Checked="NavButton_Checked"/>
                        <RadioButton x:Name="NavDiagnostics" Content="Диагностика" Tag="🔬"
                                     Style="{StaticResource NavButtonStyle}"
                                     Checked="NavButton_Checked"/>
                        <RadioButton x:Name="NavBenchmark" Content="Бенчмарк" Tag="🏁"
                                     Style="{StaticResource NavButtonStyle}"
                                     Checked="NavButton_Checked"/>
                        <RadioButton x:Name="NavLogs" Content="Логи" Tag="📋"
                                     Style="{StaticResource NavButtonStyle}"
                                     Checked="NavButton_Checked"/>
                        <RadioButton x:Name="NavSettings" Content="Настройки" Tag="⚙"
                                     Style="{StaticResource NavButtonStyle}"
                                     Checked="NavButton_Checked"/>

                        <Separator Background="#1D1D32" Margin="8,16"/>

                        <!-- Quick stats in sidebar -->
                        <Border CornerRadius="14" Padding="12" Margin="4,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#11111E" Offset="0"/>
                                    <GradientStop Color="#0A0A10" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#1D1D32"/>
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <StackPanel>
                                <TextBlock Text="БЫСТРАЯ СТАТИСТИКА" Foreground="#3F4666" FontSize="9" FontWeight="Bold" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="FPS" Foreground="#6E748D" FontSize="11"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentFPS, StringFormat={}{0:F0}}" Foreground="#F5F7FF" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="CPU" Foreground="#6E748D" FontSize="11"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CpuUsage, StringFormat={}{0:F0}%}" Foreground="#A78BFA" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="GPU" Foreground="#6E748D" FontSize="11"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding GpuUsage, StringFormat={}{0:F0}%}" Foreground="#F59E0B" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="RAM" Foreground="#6E748D" FontSize="11"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding RamUsage, StringFormat={}{0:F0}%}" Foreground="#EC4899" FontSize="11" FontWeight="SemiBold"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ===== CONTENT PAGES ===== -->
                <Grid Grid.Column="1" x:Name="ContentArea">

                    <!-- PAGE: OPTIMIZATION -->
                    <Border x:Name="PageOptimization" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="16">
                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                                    <StackPanel Margin="18">
                                        <TextBlock Text="ОПТИМИЗАЦИЯ MAX FPS" Foreground="#8B90A8" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <TextBlock Text="Одна кнопка применяет агрессивный профиль Maximum FPS: приоритет игры, очистка памяти, закрытие лишних процессов и отключение фоновых ограничений." Foreground="#A0A4BD" FontSize="13" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <!-- Action buttons -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <Button Content="⚡  ОПТИМИЗИРОВАТЬ" Command="{Binding OptimizeCommand}"
                                            IsEnabled="{Binding IsOptimizing, Converter={StaticResource InverseBooleanConverter}}"
                                            Height="50" Width="230" Style="{StaticResource PrimaryButtonStyle}"/>
                                    <Button Content="↩ Восстановить" Command="{Binding RestoreDefaultsCommand}"
                                            IsEnabled="{Binding IsOptimizing, Converter={StaticResource InverseBooleanConverter}}"
                                            Height="50" Width="160" Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0"/>
                                    <Button Content="🔄 Обновить" Command="{Binding RefreshMetricsCommand}"
                                            MinHeight="50" MinWidth="130" Padding="18,12" Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0"/>
                                </StackPanel>

                                <!-- Metric cards -->
                                <UniformGrid Columns="4" Margin="0,0,0,16">
                                    <Border Style="{StaticResource MetricCard}" Margin="0,0,6,0">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                                                <TextBlock Text="FPS" Foreground="#8B90A8" FontSize="11" FontWeight="SemiBold"/>
                                                <Ellipse Width="7" Height="7" Margin="8,0,0,0" Fill="#22C55E">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect Color="#22C55E" BlurRadius="10" ShadowDepth="0" Opacity="0.55"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </StackPanel>
                                            <TextBlock Text="{Binding CurrentFPS, StringFormat={}{0:F0}, TargetNullValue=—}" Foreground="#F5F7FF" FontSize="42" FontWeight="SemiBold" Margin="0,10,0,0"/>
                                            <ProgressBar Value="{Binding CurrentFPS}" Maximum="144" Height="4" Margin="0,12,0,0" Foreground="#22C55E" Background="#151526"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource MetricCard}" Margin="6,0,6,0">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                                                <TextBlock Text="CPU" Foreground="#8B90A8" FontSize="11" FontWeight="SemiBold"/>
                                                <Ellipse Width="7" Height="7" Margin="8,0,0,0" Fill="#6366F1">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect Color="#6366F1" BlurRadius="10" ShadowDepth="0" Opacity="0.55"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                <TextBlock Text="{Binding CpuUsage, StringFormat={}{0:F0}}" Foreground="#F5F7FF" FontSize="42" FontWeight="SemiBold"/>
                                                <TextBlock Text="%" Foreground="#8B90A8" FontSize="18" FontWeight="SemiBold"/>
                                            </StackPanel>
                                            <ProgressBar Value="{Binding CpuUsage}" Maximum="100" Height="4" Margin="0,12,0,0" Foreground="#6366F1" Background="#151526"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource MetricCard}" Margin="6,0,6,0">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                                                <TextBlock Text="GPU" Foreground="#8B90A8" FontSize="11" FontWeight="SemiBold"/>
                                                <Ellipse Width="7" Height="7" Margin="8,0,0,0" Fill="#F59E0B">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect Color="#F59E0B" BlurRadius="10" ShadowDepth="0" Opacity="0.55"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                <TextBlock Text="{Binding GpuUsage, StringFormat={}{0:F0}}" Foreground="#F5F7FF" FontSize="42" FontWeight="SemiBold"/>
                                                <TextBlock Text="%" Foreground="#8B90A8" FontSize="18" FontWeight="SemiBold"/>
                                            </StackPanel>
                                            <ProgressBar Value="{Binding GpuUsage}" Maximum="100" Height="4" Margin="0,12,0,0" Foreground="#F59E0B" Background="#151526"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource MetricCard}" Margin="6,0,0,0">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                                                <TextBlock Text="RAM" Foreground="#8B90A8" FontSize="11" FontWeight="SemiBold"/>
                                                <Ellipse Width="7" Height="7" Margin="8,0,0,0" Fill="#EC4899">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect Color="#EC4899" BlurRadius="10" ShadowDepth="0" Opacity="0.55"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                <TextBlock Text="{Binding RamUsage, StringFormat={}{0:F0}}" Foreground="#F5F7FF" FontSize="42" FontWeight="SemiBold"/>
                                                <TextBlock Text="%" Foreground="#8B90A8" FontSize="18" FontWeight="SemiBold"/>
                                            </StackPanel>
                                            <ProgressBar Value="{Binding RamUsage}" Maximum="100" Height="4" Margin="0,12,0,0" Foreground="#EC4899" Background="#151526"/>
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- PAGE: MONITORING -->
                    <Border x:Name="PageMonitoring" Visibility="Collapsed">
                        <Grid Margin="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,12">
                                <Border Style="{StaticResource CardStyle}" Margin="0,0,6,0">
                                    <StackPanel Margin="16">
                                        <TextBlock Text="🖥  CPU" Foreground="#6366F1" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Загрузка" Foreground="#555570" FontSize="11"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Monitor.SmoothedCpu, StringFormat={}{0:F1}%}" Foreground="White" FontSize="11"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Игра" Foreground="#555570" FontSize="11"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Monitor.Metrics.CPUUsageGame, StringFormat={}{0:F1}%}" Foreground="White" FontSize="11"/>
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Температура" Foreground="#555570" FontSize="11"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Monitor.Metrics.CPUTemperature, StringFormat={}{0:F0}°C}" Foreground="White" FontSize="11"/>
                                        </Grid>
                                        <ProgressBar Value="{Binding Monitor.SmoothedCpu}" Maximum="100" Height="3" Margin="0,10,0,0" Foreground="#6366F1" Background="#1A1A2E"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardStyle}" Margin="6,0,6,0">
                                    <StackPanel Margin="16">
                                        <TextBlock Text="💾  RAM" Foreground="#EC4899" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Использовано" Foreground="#555570" FontSize="11"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Foreground="White" FontSize="11">
                                                <TextBlock.Text><Binding Path="Monitor.Metrics.UsedRAM" Converter="{StaticResource BytesToMBConverter}"/></TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Standby" Foreground="#555570" FontSize="11"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Monitor.Metrics.StandbyMemoryMB, StringFormat={}{0:F0} MB, Mode=OneWay}" Foreground="White" FontSize="11"/>
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Игра" Foreground="#555570" FontSize="11"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Monitor.Metrics.GameRAM_MB, StringFormat={}{0:F0} MB, Mode=OneWay}" Foreground="White" FontSize="11"/>
                                        </Grid>
                                        <ProgressBar Value="{Binding Monitor.SmoothedRam}" Maximum="100" Height="3" Margin="0,10,0,0" Foreground="#EC4899" Background="#1A1A2E"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource CardStyle}" Margin="6,0,0,0">
                                    <StackPanel Margin="16">
                                        <TextBlock Text="📡  Диск &amp; Сеть" Foreground="#F59E0B" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Чтение" Foreground="#555570" FontSize="11"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Monitor.Metrics.DiskReadSpeedMBps, StringFormat={}{0:F1} MB/s}" Foreground="White" FontSize="11"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Запись" Foreground="#555570" FontSize="11"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Monitor.Metrics.DiskWriteSpeedMBps, StringFormat={}{0:F1} MB/s}" Foreground="White" FontSize="11"/>
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Пинг" Foreground="#555570" FontSize="11"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Monitor.Metrics.CurrentPing, StringFormat={}{0:F0} ms}" Foreground="White" FontSize="11"/>
                                        </Grid>
                                        <ProgressBar Value="{Binding Monitor.Metrics.DiskActiveTimePercent}" Maximum="100" Height="3" Margin="0,10,0,0" Foreground="#F59E0B" Background="#1A1A2E"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                                <StackPanel Margin="16">
                                    <TextBlock Text="🔍  АНАЛИЗ УЗКИХ МЕСТ" Foreground="White" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding Monitor.Bottleneck.PrimaryBottleneck, StringFormat={}Основное ограничение: {0}, TargetNullValue='Анализ...', FallbackValue='Анализ...'}" Foreground="#555570" FontSize="11" Margin="0,0,0,12"/>
                                    <ItemsControl ItemsSource="{Binding Monitor.Bottleneck.Details}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#0E0E18" CornerRadius="8" Padding="12" Margin="0,4">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Severity, StringFormat={}{0:F0}}" FontWeight="Bold" FontSize="14" Width="40"
                                                                       Foreground="{Binding Severity, Converter={StaticResource SeverityToColorConverter}}"/>
                                                            <TextBlock Text="{Binding Description}" Foreground="#A0A0C0" FontSize="12" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Recommendation}" Foreground="#555570" FontSize="11" Margin="40,4,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Border Margin="0,12,0,0" CornerRadius="8" Padding="12">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#0A1F0A"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Monitor.Metrics.IsPerformanceGood, Mode=OneWay}" Value="False">
                                                        <Setter Property="Background" Value="#1F0A0A"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Monitor.Metrics.PerformanceStatus, Mode=OneWay}" FontSize="18" FontWeight="Light" HorizontalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#22C55E"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Monitor.Metrics.IsPerformanceGood, Mode=OneWay}" Value="False">
                                                            <Setter Property="Foreground" Value="#EF4444"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- PAGE: DIAGNOSTICS -->
                    <Border x:Name="PageDiagnostics" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="16">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <Button Content="🔬  Запустить диагностику" Command="{Binding Diagnostics.RunDiagnosticsCommand}"
                                            IsEnabled="{Binding Diagnostics.IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                                            Height="48" Width="240" Style="{StaticResource PrimaryButtonStyle}"/>
                                    <TextBlock Text="{Binding Diagnostics.StatusText}" Foreground="#606080" VerticalAlignment="Center" FontSize="12" Margin="16,0,0,0"/>
                                </StackPanel>

                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12" Visibility="{Binding Diagnostics.ReadinessScore, Converter={StaticResource HasContentToVisibilityConverter}}">
                                    <StackPanel Margin="18">
                                        <TextBlock Text="🏆  ОЦЕНКА ГОТОВНОСТИ ПК" Foreground="White" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" HorizontalAlignment="Center" Margin="0,0,24,0">
                                                <TextBlock Text="{Binding Diagnostics.ReadinessScore.OverallScore}" FontSize="56" FontWeight="Light"
                                                           Foreground="{Binding Diagnostics.ReadinessScore.OverallColor}" HorizontalAlignment="Center"/>
                                                <TextBlock Text="из 100" Foreground="#555570" FontSize="12" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Diagnostics.ReadinessScore.Summary}" Foreground="#A0A0C0" FontSize="13" Margin="0,0,0,8"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="CPU" Foreground="#555570" FontSize="11"/>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Diagnostics.ReadinessScore.CpuScore, StringFormat={}{0}/100}" Foreground="White" FontSize="11"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="GPU" Foreground="#555570" FontSize="11"/>
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Diagnostics.ReadinessScore.GpuScore, StringFormat={}{0}/100}" Foreground="White" FontSize="11"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="RAM" Foreground="#555570" FontSize="11"/>
                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Diagnostics.ReadinessScore.RamScore, StringFormat={}{0}/100}" Foreground="White" FontSize="11"/>
                                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Storage" Foreground="#555570" FontSize="11"/>
                                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Diagnostics.ReadinessScore.StorageScore, StringFormat={}{0}/100}" Foreground="White" FontSize="11"/>
                                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Network" Foreground="#555570" FontSize="11"/>
                                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Diagnostics.ReadinessScore.NetworkScore, StringFormat={}{0}/100}" Foreground="White" FontSize="11"/>
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="{Binding Diagnostics.ReadinessScore.CpuName}" Foreground="#606080" FontSize="10" Margin="0,8,0,0"/>
                                        <TextBlock Text="{Binding Diagnostics.ReadinessScore.GpuName}" Foreground="#606080" FontSize="10"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12" Visibility="{Binding Diagnostics.HasIssues, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Margin="18">
                                        <TextBlock Text="⚠  ПРОБЛЕМЫ" Foreground="#EF4444" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                        <ItemsControl ItemsSource="{Binding Diagnostics.Issues}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#1A0A0A" CornerRadius="8" Padding="12" Margin="0,4" BorderBrush="#2A1010" BorderThickness="1">
                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Ellipse Width="8" Height="8" Fill="{Binding SeverityColor}" Margin="0,0,8,0"/>
                                                                <TextBlock Text="{Binding Title}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding Description}" Foreground="#A0A0C0" FontSize="12" Margin="16,4,0,0"/>
                                                            <TextBlock Text="{Binding Recommendation}" Foreground="#606080" FontSize="11" Margin="16,4,0,0" FontStyle="Italic"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12" Visibility="{Binding Diagnostics.HasWarnings, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Margin="18">
                                        <TextBlock Text="⚡ ПРЕДУПРЕЖДЕНИЯ" Foreground="#F59E0B" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                        <ItemsControl ItemsSource="{Binding Diagnostics.Warnings}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#1A150A" CornerRadius="8" Padding="12" Margin="0,4" BorderBrush="#2A2010" BorderThickness="1">
                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal">
                                                                <Ellipse Width="8" Height="8" Fill="{Binding SeverityColor}" Margin="0,0,8,0"/>
                                                                <TextBlock Text="{Binding Title}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding Description}" Foreground="#A0A0C0" FontSize="12" Margin="16,4,0,0"/>
                                                            <TextBlock Text="{Binding Recommendation}" Foreground="#606080" FontSize="11" Margin="16,4,0,0" FontStyle="Italic"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}" Visibility="{Binding Diagnostics.HasGtaVAnalysis, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Margin="18">
                                        <TextBlock Text="🎮  АНАЛИЗ НАСТРОЕК GTA V" Foreground="White" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="Оценка настроек: " Foreground="#555570" FontSize="12"/>
                                            <TextBlock Text="{Binding Diagnostics.GtaVAnalysis.PerformanceScore}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                                            <TextBlock Text="/100" Foreground="#555570" FontSize="12"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="Проблем: " Foreground="#555570" FontSize="12"/>
                                            <TextBlock Text="{Binding Diagnostics.GtaVAnalysis.IssueCount}" Foreground="#F59E0B" FontSize="12"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Diagnostics.GtaVAnalysis.SettingsPath, StringFormat={}Путь: {0}}" Foreground="#444460" FontSize="10" Margin="0,0,0,8" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="Рекомендации:" Foreground="#808090" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <ItemsControl ItemsSource="{Binding Diagnostics.GtaVAnalysis.TopRecommendations}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#0E0E18" CornerRadius="6" Padding="10" Margin="0,3">
                                                        <TextBlock Text="{Binding}" Foreground="#A0A0C0" FontSize="11" TextWrapping="Wrap"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Text="Найденные проблемы:" Foreground="#808090" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,6"
                                                   Visibility="{Binding Diagnostics.GtaVAnalysis.TopIssues.Count, Converter={StaticResource HasContentToVisibilityConverter}}"/>
                                        <ItemsControl ItemsSource="{Binding Diagnostics.GtaVAnalysis.TopIssues}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#1A0A0A" CornerRadius="6" Padding="10" Margin="0,3">
                                                        <TextBlock Text="{Binding}" Foreground="#EF4444" FontSize="11" TextWrapping="Wrap"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- GTA V Analysis placeholder when game not found -->
                                <Border Style="{StaticResource CardStyle}" Visibility="{Binding Diagnostics.GtaVAnalysis, Converter={StaticResource HasContentToVisibilityConverter}, ConverterParameter=Invert}">
                                    <StackPanel Margin="18">
                                        <TextBlock Text="🎮  АНАЛИЗ НАСТРОЕК GTA V" Foreground="White" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <TextBlock Text="GTA V не обнаружена. Анализ настроек графики будет доступен после обнаружения игры." Foreground="#606080" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- PAGE: BENCHMARK -->
                    <Border x:Name="PageBenchmark" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Style="{StaticResource HudScrollViewer}">
                            <StackPanel Margin="16">
                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                                    <StackPanel Margin="18">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                            <TextBlock Text="🏁" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="БЕНЧМАРК" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <Border CornerRadius="8" Padding="8,3" Margin="12,0,0,0" Background="#1A1508" BorderBrush="#2A2010" BorderThickness="1">
                                                <TextBlock Text="Majestic RP" Foreground="#F59E0B" FontSize="10" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Duration selector chips -->
                                        <TextBlock Text="Длительность теста" Foreground="#555570" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,16">
                                            <RadioButton Content="15 сек" IsChecked="{Binding Benchmark.IsDuration15}"
                                                         Style="{StaticResource DurationChipStyle}" Checked="DurationChip_Checked" Tag="15"/>
                                            <RadioButton Content="30 сек" IsChecked="{Binding Benchmark.IsDuration30}"
                                                         Style="{StaticResource DurationChipStyle}" Checked="DurationChip_Checked" Tag="30"/>
                                            <RadioButton Content="60 сек" IsChecked="{Binding Benchmark.IsDuration60}"
                                                         Style="{StaticResource DurationChipStyle}" Checked="DurationChip_Checked" Tag="60"/>
                                            <RadioButton Content="120 сек" IsChecked="{Binding Benchmark.IsDuration120}"
                                                         Style="{StaticResource DurationChipStyle}" Checked="DurationChip_Checked" Tag="120"/>
                                        </StackPanel>

                                        <!-- Action buttons -->
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="▶  ЗАПУСТИТЬ" Command="{Binding Benchmark.RunBenchmarkCommand}"
                                                    IsEnabled="{Binding Benchmark.IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                                                    Style="{StaticResource BenchmarkPrimaryButton}" Width="180"/>
                                            <Button Content="📸 ДО" Command="{Binding Benchmark.CaptureBeforeCommand}"
                                                    IsEnabled="{Binding Benchmark.IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                                                    Style="{StaticResource BenchmarkSecondaryButton}" Margin="8,0,0,0"/>
                                            <Button Content="📸 ПОСЛЕ" Command="{Binding Benchmark.CaptureAfterCommand}"
                                                    IsEnabled="{Binding Benchmark.IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                                                    Style="{StaticResource BenchmarkSecondaryButton}" Margin="8,0,0,0"/>
                                            <Button Content="🔄 СБРОС" Command="{Binding Benchmark.ResetCommand}"
                                                    Style="{StaticResource BenchmarkSecondaryButton}" Margin="8,0,0,0"/>
                                        </StackPanel>

                                        <!-- Status bar -->
                                        <Border CornerRadius="10" Padding="12,8" Margin="0,12,0,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#0A0A12" Offset="0"/>
                                                    <GradientStop Color="#0E0E18" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="6" Height="6" Margin="0,0,8,0" VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Fill" Value="#22C55E"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Benchmark.IsRunning}" Value="True">
                                                                    <Setter Property="Fill" Value="#F59E0B"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Text="{Binding Benchmark.StatusText}" Foreground="#8B90A8" FontSize="11"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12" Visibility="{Binding Benchmark.Result, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Margin="18">
                                        <TextBlock Text="📊  РЕЗУЛЬТАТЫ" Foreground="White" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                        <UniformGrid Columns="4">
                                            <StackPanel>
                                                <TextBlock Text="Средний FPS" Foreground="#555570" FontSize="10"/>
                                                <TextBlock Text="{Binding Benchmark.Result.AverageFPS, StringFormat={}{0:F1}}" Foreground="White" FontSize="28" FontWeight="Light"/>
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="1% Low" Foreground="#555570" FontSize="10"/>
                                                <TextBlock Text="{Binding Benchmark.Result.OnePercentLowFPS, StringFormat={}{0:F1}}" Foreground="White" FontSize="28" FontWeight="Light"/>
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="0.1% Low" Foreground="#555570" FontSize="10"/>
                                                <TextBlock Text="{Binding Benchmark.Result.PointOnePercentLowFPS, StringFormat={}{0:F1}}" Foreground="White" FontSize="28" FontWeight="Light"/>
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="Frametime" Foreground="#555570" FontSize="10"/>
                                                <TextBlock Text="{Binding Benchmark.Result.AverageFrameTimeMs, StringFormat={}{0:F1} ms}" Foreground="White" FontSize="28" FontWeight="Light"/>
                                            </StackPanel>
                                        </UniformGrid>
                                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                            <TextBlock Text="Оценка: " Foreground="#555570" FontSize="12"/>
                                            <TextBlock Text="{Binding Benchmark.Result.PerformanceGrade}" Foreground="White" FontSize="12" FontWeight="Bold"/>
                                            <TextBlock Text="  •  Фризы: " Foreground="#555570" FontSize="12" Margin="16,0,0,0"/>
                                            <TextBlock Text="{Binding Benchmark.Result.StutterCount}" Foreground="White" FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}" Visibility="{Binding Benchmark.Comparison.BeforeSnapshot, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Margin="18">
                                        <TextBlock Text="⚖  СРАВНЕНИЕ ДО / ПОСЛЕ" Foreground="White" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                        <TextBlock Text="{Binding Benchmark.Comparison.Summary}" Foreground="#818CF8" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="ДО" Foreground="#555570" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                                                <TextBlock Text="{Binding Benchmark.Comparison.BeforeSnapshot.FPS, StringFormat=FPS: {0:F1}}" Foreground="White" FontSize="12"/>
                                                <TextBlock Text="{Binding Benchmark.Comparison.BeforeSnapshot.CPUUsage, StringFormat=CPU: {0:F1}%}" Foreground="#A0A0C0" FontSize="11"/>
                                                <TextBlock Text="{Binding Benchmark.Comparison.BeforeSnapshot.GPUUsage, StringFormat=GPU: {0:F1}%}" Foreground="#A0A0C0" FontSize="11"/>
                                                <TextBlock Text="{Binding Benchmark.Comparison.BeforeSnapshot.RAMUsage, StringFormat=RAM: {0:F1}%}" Foreground="#A0A0C0" FontSize="11"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="→" Foreground="#555570" FontSize="24" VerticalAlignment="Center" Margin="16,0"/>
                                            <StackPanel Grid.Column="2" Visibility="{Binding Benchmark.Comparison.AfterSnapshot, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="ПОСЛЕ" Foreground="#555570" FontSize="10" FontWeight="Bold" Margin="0,0,0,6"/>
                                                <TextBlock Text="{Binding Benchmark.Comparison.AfterSnapshot.FPS, StringFormat=FPS: {0:F1}}" Foreground="White" FontSize="12"/>
                                                <TextBlock Text="{Binding Benchmark.Comparison.AfterSnapshot.CPUUsage, StringFormat=CPU: {0:F1}%}" Foreground="#A0A0C0" FontSize="11"/>
                                                <TextBlock Text="{Binding Benchmark.Comparison.AfterSnapshot.GPUUsage, StringFormat=GPU: {0:F1}%}" Foreground="#A0A0C0" FontSize="11"/>
                                                <TextBlock Text="{Binding Benchmark.Comparison.AfterSnapshot.RAMUsage, StringFormat=RAM: {0:F1}%}" Foreground="#A0A0C0" FontSize="11"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- PAGE: LOGS -->
                    <Border x:Name="PageLogs" Visibility="Collapsed">
                        <Grid Margin="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Content="↻ Обновить" Command="{Binding Logs.RefreshCommand}" MinHeight="38" MinWidth="120" Padding="18,10" Style="{StaticResource SecondaryButtonStyle}"/>
                                <Button Content="🗑 Очистить" Command="{Binding Logs.ClearCommand}" MinHeight="38" MinWidth="120" Padding="18,10" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0"/>
                                <TextBlock Foreground="#555570" VerticalAlignment="Center" FontSize="11" Margin="15,0,0,0">
                                    <Run Text="Записей: "/><Run Text="{Binding Logs.Logs.Count, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                                <ListView ItemsSource="{Binding Logs.Logs}" Background="Transparent" BorderThickness="0"
                                          Foreground="#A0A0C0" FontSize="12" FontFamily="Consolas, 'Courier New', monospace"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="Padding" Value="12,5"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="BorderBrush" Value="#151525"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#12121E"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="75"/>
                                                    <ColumnDefinition Width="85"/>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding ShortTime}" Foreground="#444460" FontSize="11"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Level}" FontSize="11" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#666680"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Level}" Value="Information"><Setter Property="Foreground" Value="#6366F1"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Level}" Value="Warning"><Setter Property="Foreground" Value="#F59E0B"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Level}" Value="Error"><Setter Property="Foreground" Value="#EF4444"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Level}" Value="Critical"><Setter Property="Foreground" Value="#DC2626"/></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Grid.Column="2" Text="{Binding Category}" Foreground="#333350" FontSize="11"/>
                                                <TextBlock Grid.Column="3" Text="{Binding Message}" Foreground="#808090" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- PAGE: SETTINGS -->
                    <Border x:Name="PageSettings" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="16">
                            <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                                    <StackPanel Margin="18">
                                        <TextBlock Text="🔄 АВТООПТИМИЗАЦИЯ" Foreground="White" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <CheckBox Content="Включить автооптимизацию" IsChecked="{Binding Settings.EnableAutoOptimization}" Foreground="#A0A0C0" FontSize="12" Margin="0,0,0,10"/>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="Интервал:" Foreground="#555570" FontSize="12" VerticalAlignment="Center" Width="80"/>
                                            <TextBlock Text="{Binding Settings.AutoOptimizationInterval}" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Text=" сек" Foreground="#555570" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                                    <StackPanel Margin="18">
                                        <TextBlock Text="🎮 ИГРОВЫЕ ФУНКЦИИ" Foreground="White" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding OverlayEnabled}" VerticalAlignment="Center"/>
                                            <TextBlock Text="Оверлей в игре (FPS, CPU, GPU)" Foreground="#A0A0C0" FontSize="12" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <CheckBox Style="{StaticResource ToggleSwitch}" IsChecked="{Binding AutoStartEnabled}" VerticalAlignment="Center"/>
                                            <TextBlock Text="Автозапуск с Windows" Foreground="#A0A0C0" FontSize="12" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="Горячая клавиша: Ctrl+Alt+O — быстрая оптимизация" Foreground="#444460" FontSize="10" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                                    <StackPanel Margin="18">
                                        <TextBlock Text="🎯 ДОПОЛНИТЕЛЬНО" Foreground="White" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <CheckBox Content="Закрывать браузеры" IsChecked="{Binding Settings.CloseBrowsers}" Foreground="#A0A0C0" FontSize="12" Margin="0,0,0,6"/>
                                        <CheckBox Content="Отключать Discord Overlay" IsChecked="{Binding Settings.CloseDiscordOverlay}" Foreground="#A0A0C0" FontSize="12" Margin="0,0,0,6"/>
                                        <CheckBox Content="Очищать память" IsChecked="{Binding Settings.EnableMemoryCleanup}" Foreground="#A0A0C0" FontSize="12"/>
                                    </StackPanel>
                                </Border>

                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Button Content="💾 Сохранить" Command="{Binding Settings.SaveCommand}" Style="{StaticResource PrimaryButtonStyle}" Height="40" Width="150"/>
                                    <Button Content="↩ Сбросить" Command="{Binding Settings.ResetCommand}" Style="{StaticResource SecondaryButtonStyle}" Height="40" Width="130" Margin="10,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                </Grid>
            </Grid>

            <!-- STATUS BAR -->
            <Border Grid.Row="2" Background="#0E0E18" BorderBrush="#151525" BorderThickness="0,1,0,0">
                <Grid Margin="16,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding GameStatusText}" Foreground="#444460" FontSize="10" VerticalAlignment="Center"/>
                        <TextBlock Text="  •  " Foreground="#2A2A40" FontSize="10" VerticalAlignment="Center"/>
                        <TextBlock Foreground="#333350" FontSize="10" VerticalAlignment="Center">
                            <Run Text="Ctrl+Alt+O — оптимизация"/>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Foreground="#333350" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <Run Text="GTA5 Optimizer "/><Run Text="{Binding Version}"/>
                    </TextBlock>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
