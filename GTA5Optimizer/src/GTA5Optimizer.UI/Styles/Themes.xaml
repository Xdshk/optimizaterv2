<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Цветовая палитра -->
    <SolidColorBrush x:Key="BackgroundColor" Color="#121212"/>
    <SolidColorBrush x:Key="PanelColor" Color="#1e1e1e"/>
    <SolidColorBrush x:Key="BorderColor" Color="#333333"/>
    <SolidColorBrush x:Key="AccentColor" Color="#00d4ff"/>
    <SolidColorBrush x:Key="SuccessColor" Color="#00ff88"/>
    <SolidColorBrush x:Key="WarningColor" Color="#ffaa00"/>
    <SolidColorBrush x:Key="ErrorColor" Color="#ff4444"/>
    <SolidColorBrush x:Key="TextColor" Color="#ffffff"/>
    <SolidColorBrush x:Key="SecondaryTextColor" Color="#aaaaaa"/>

    <!-- Стиль кнопки -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#00d4ff"/>
        <Setter Property="Foreground" Value="#000000"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="#005555"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#00ffff"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Стиль вкладок -->
    <Style x:Key="MainTabStyle" TargetType="TabControl">
        <Setter Property="Background" Value="#121212"/>
        <Setter Property="Foreground" Value="#ffffff"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- Стиль закладки -->
    <Style x:Key="TabItemStyle" TargetType="TabItem">
        <Setter Property="Background" Value="#1e1e1e"/>
        <Setter Property="Foreground" Value="#aaaaaa"/>
        <Setter Property="Padding" Value="20,10"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#121212"/>
                <Setter Property="Foreground" Value="#00d4ff"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>